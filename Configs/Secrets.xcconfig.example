# copy to Secrets.xcconfig and fill
GOOGLE_OAUTH_KEY_DEV = 
GOOGLE_OAUTH_KEY_PROD =
GOOGLE_OAUTH_REDIRECT_SCHEME_DEV = com.googleusercontent.apps.dev-client-id
GOOGLE_OAUTH_REDIRECT_SCHEME_PROD = com.googleusercontent.apps.prod-client-id
AMPLITUDE_API_KEY_DEV = amplitude-dev-key
AMPLITUDE_API_KEY_PROD = amplitude-prod-key
SUPPORT_EMAIL_DEV = support@yourdomain.com
SUPPORT_EMAIL_PROD = support@yourdomain.com
