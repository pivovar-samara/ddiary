          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra tu glucosa 2 horas después del desayuno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez votre glycémie 2 heures après le petit-déjeuner."
