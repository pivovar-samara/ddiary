    "app.startup.recovery_hint" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى إعادة تشغيل التطبيق. إذا استمرت المشكلة، أعد تثبيت التطبيق أو تواصل مع الدعم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte starte die App neu. Wenn das Problem weiterhin besteht, installiere die App neu oder kontaktiere den Support."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please restart the app. If the problem persists, reinstall the app or contact support."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, reinicia la aplicación. Si el problema persiste, reinstala la aplicación o contacta con soporte."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veuillez redémarrer l'application. Si le problème persiste, réinstallez l'application ou contactez le support."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riavvia l'app. Se il problema persiste, reinstalla l'app o contatta il supporto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリを再起動してください。問題が解決しない場合は、アプリを再インストールするかサポートにお問い合わせください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱을 다시 시작하세요. 문제가 지속되면 앱을 재설치하거나 지원팀에 문의하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start de app opnieuw. Als het probleem aanhoudt, installeer de app opnieuw of neem contact op met ondersteuning."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uruchom ponownie aplikację. Jeśli problem będzie się powtarzał, zainstaluj aplikację ponownie lub skontaktuj się z pomocą techniczną."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por favor, reinicie o app. Se o problema persistir, reinstale o app ou entre em contato com o suporte."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перезапустите приложение. Если проблема повторится, переустановите приложение или обратитесь в поддержку."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starta om appen. Om problemet kvarstår, installera om appen eller kontakta supporten."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lütfen uygulamayı yeniden başlatın. Sorun devam ederse uygulamayı yeniden yükleyin veya destekle iletişime geçin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Будь ласка, перезапустіть додаток. Якщо проблема не зникне, перевстановіть додаток або зверніться до служби підтримки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请重启应用。如果问题持续，请重新安装应用或联系支持团队。"
          }
        }
      }
