    "settings.disclaimer.medical" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary ليس جهازًا طبيًا. استشر طبيبك للحصول على المشورة الطبية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary ist kein Medizinprodukt. Konsultiere deinen Arzt für medizinischen Rat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary is not a medical device. Consult your physician for medical advice."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary no es un dispositivo médico. Consulta a tu médico para obtener asesoramiento médico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary n'est pas un dispositif médical. Consultez votre médecin pour tout conseil médical."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary non è un dispositivo medico. Consulta il tuo medico per consigli medici."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiaryは医療機器ではありません。医療上のアドバイスは医師にご相談ください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary는 의료 기기가 아닙니다. 의료 조언은 의사에게 상담하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary is geen medisch hulpmiddel. Raadpleeg uw arts voor medisch advies."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary nie jest urządzeniem medycznym. Skonsultuj się z lekarzem w sprawie porad medycznych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary não é um dispositivo médico. Consulte seu médico para aconselhamento médico."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DDiary не является медицинским устройством. Обратитесь к врачу за медицинской консультацией."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
