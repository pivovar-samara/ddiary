  "strings": {
    "": {},
    "%@/%@/%@": {
      "comment": "A formatted string showing the minimum, maximum, and average systolic blood pressure values.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@/%2$@/%3$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A text view displaying an integer value.",
      "isCommentAutoGenerated": true
    },
    "%lld/%lld": {
      "comment": "A label that shows a blood pressure measurement in the format \"120/80\". The first argument is the systolic pressure value. The second argument is the diastolic pressure value.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld/%2$lld"
          }
        }
      }
    },
    "%lldh": {},
    "%lldm": {
      "comment": "A text view displaying the number of minutes selected in the meal offset editor.",
      "isCommentAutoGenerated": true
    },
    "0": {
